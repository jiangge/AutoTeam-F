# ---- Mail Provider ----
# ⚠️  强烈推荐显式设置 MAIL_PROVIDER —— 不设默认 cf_temp_email,可能与 maillab 部署错配
#     触发 issue#1「登录成功 → 创建邮箱 401」半成功假象。SetupPage 已支持在线选择 + 验证。
# 可选值:cf_temp_email | maillab
#   - cf_temp_email = dreamhunter2333/cloudflare_temp_email
#   - maillab       = maillab/cloud-mail(含 skymail.ink 官方部署)
MAIL_PROVIDER=cf_temp_email

# CloudMail (cf_temp_email 后端配置;命名沿用 CLOUDMAIL_* 是历史兼容)
# CLOUDMAIL_BASE_URL 必须填写到 API 前缀，示例: https://example.com/api
CLOUDMAIL_BASE_URL=https://example.com/api
CLOUDMAIL_PASSWORD=your_password           # cf_temp_email 的 admin password
CLOUDMAIL_DOMAIN=@example.com
# CLOUDMAIL_EMAIL 已废弃;保留只为兼容旧 .env,不再被使用
CLOUDMAIL_EMAIL=

# Maillab (MAIL_PROVIDER=maillab 时启用;Web 面板 SetupPage / Settings 可填)
MAILLAB_API_URL=
MAILLAB_USERNAME=
MAILLAB_PASSWORD=
MAILLAB_DOMAIN=                            # 创建邮箱时使用,缺省回落 CLOUDMAIL_DOMAIN

# CPA (CLIProxyAPI)
CPA_URL=http://127.0.0.1:8317
CPA_KEY=your_key

# 远端同步目标开关（建议显式设置，避免占位值被误判为已启用）
SYNC_TARGET_CPA=false
SYNC_TARGET_SUB2API=false

# Sub2API
SUB2API_URL=http://127.0.0.1:8080
SUB2API_EMAIL=admin@example.com
SUB2API_PASSWORD=your_password
SUB2API_GROUP=
SUB2API_PROXY=
SUB2API_CONCURRENCY=10
SUB2API_PRIORITY=1
SUB2API_RATE_MULTIPLIER=1
SUB2API_AUTO_PAUSE_ON_EXPIRED=true
SUB2API_MODEL_WHITELIST=
SUB2API_OPENAI_WS_MODE=off
SUB2API_OPENAI_PASSTHROUGH=false
SUB2API_OVERWRITE_ACCOUNT_SETTINGS=false

# API 鉴权（不设置则不启用，任何人都可访问）
API_KEY=

# Playwright 浏览器代理（可选）
# 示例：socks5://user:pass@host.docker.internal:1080
PLAYWRIGHT_PROXY_URL=
# 示例：localhost,127.0.0.1
PLAYWRIGHT_PROXY_BYPASS=

# IPv6 per-account proxy pool（默认关闭；开启前确认宿主机 IPv6 /64 和 ip 命令可用）
AUTOTEAM_IPV6_POOL_ENABLED=false
AUTOTEAM_IPV6_POOL_REQUIRED=false
IPV6_PREFIX=
IPV6_IFACE=eth0
IPV6_PROXY_USE_SUDO=false
IPV6_PROXY_LISTEN_HOST=0.0.0.0
IPV6_PROXY_LOCAL_HOST=127.0.0.1
IPV6_PROXY_PUBLIC_HOST=
IPV6_PROXY_ALLOWED_IPS=127.0.0.1
IPV6_PROXY_PORT_START=30000
IPV6_PROXY_PORT_END=39999
IPV6_PROXY_TTL_SECONDS=172800
IPV6_PROXY_POOL_FILE=

# ChatGPT Team API transport（默认对齐 autoteam-1，Team API 读取优先轻量 HTTP）
# 可选值：playwright | curl_cffi | auto
# - playwright：保持旧行为，所有 Team API 通过浏览器上下文 fetch
# - curl_cffi / auto：优先尝试轻量 HTTP transport，异常或挑战页会回退 Playwright
CHATGPT_API_TRANSPORT=auto
CHATGPT_API_HTTP_TIMEOUT=60
CHATGPT_API_IMPERSONATE=chrome136

# 轮询配置
EMAIL_POLL_INTERVAL=3
EMAIL_POLL_TIMEOUT=300

# 自动巡检（API 模式下生效）
AUTO_CHECK_INTERVAL=300      # 巡检间隔（秒），默认 5 分钟
AUTO_CHECK_TARGET_SEATS=3    # 自动巡检目标 Team 总 seat 数（最多 1 母 + 2 子）
AUTO_CHECK_THRESHOLD=10      # 额度低于此百分比触发轮转，默认 10%
AUTO_CHECK_MIN_LOW=2         # 至少几个账号低于阈值才触发，默认 2
AUTO_CHECK_RETRY_ADD_PHONE=true          # 是否自动重试 add_phone（手机号验证）
AUTO_CHECK_ADD_PHONE_MAX_RETRIES=3        # add_phone 最大自动重试次数
ROTATE_SKIP_REUSE=true                    # 轮换默认不复用旧/失败子号，满员时先移旧号再创建新号
ROTATE_MAX_DURATION=1500                  # 单次 rotate 最长运行秒数，超时优雅退出交给下轮巡检

# 多 Team 母号并行调度（每个 Team 仍保持 1 母 + 最多 2 子）
MULTI_MASTER_MAX_OWNER_WORKERS=2          # 同时处理几个母号
MULTI_MASTER_BROWSER_BUDGET=4             # owner 并发 * 单号 direct race 的总浏览器预算
MULTI_MASTER_MEMORY_DOWNGRADE_RATIO=0.85  # cgroup 内存比例超过该值时自动降级为串行
DIRECT_REGISTER_PARALLEL=1                # 单个注册目标的 direct signup race 并行度（1-4）

# 对账策略（autoteam reconcile / cmd_check 入口自动对账）
# RECONCILE_KICK_ORPHAN=true：workspace 有 active + 本地 auth_file 缺失的"残废"自动 KICK
#                        false：只标 STATUS_ORPHAN，等人工补登
RECONCILE_KICK_ORPHAN=true
# RECONCILE_KICK_GHOST=true：workspace 有 active + 本地完全无记录的"ghost"自动 KICK
#                       false：仅日志，依赖 sync_account_states 反向补录
RECONCILE_KICK_GHOST=true
